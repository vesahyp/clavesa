#!/usr/bin/env bash

# Stripped replacement for PySpark's upstream `spark-class`. Upstream uses
# bash process substitution and `ps`, both of which fail in Lambda's
# restricted runtime; this fork skips launcher.Main and execs java directly
# with a hard-coded classpath (originally from aws-samples/spark-on-aws-lambda).
#
# v2.0.0 adds the 15 --add-opens flags Spark 4 expects under Java 17. Mirrors
# Spark's own JavaModuleOptions.java at the v4.0.2 tag. Without these, any
# off-heap shuffle / DirectBuffer path (e.g. StorageUtils.bufferCleaner)
# throws InaccessibleObjectException once a query needs to spill.

# Debug: Print environment variables
echo "JAVA_HOME: $JAVA_HOME" >&2
echo "PATH: $PATH" >&2

# Hard-code the Java executable path for maximum reliability
JAVA_EXECUTABLE="/usr/bin/java"

# Fallback options if the hard-coded path doesn't work
if [ ! -f "$JAVA_EXECUTABLE" ]; then
  echo "Primary Java path not found, trying alternatives..." >&2
  
  # Try using JAVA_HOME
  if [ -n "$JAVA_HOME" ] && [ -f "$JAVA_HOME/bin/java" ]; then
    JAVA_EXECUTABLE="$JAVA_HOME/bin/java"
    echo "Using Java from JAVA_HOME: $JAVA_EXECUTABLE" >&2
  # Try Java 17 Amazon Corretto path
  elif [ -f "/usr/lib/jvm/java-17-amazon-corretto/bin/java" ]; then
    JAVA_EXECUTABLE="/usr/lib/jvm/java-17-amazon-corretto/bin/java"
    echo "Using Java from Amazon Corretto path: $JAVA_EXECUTABLE" >&2
  # Try common JRE path (for compatibility)
  elif [ -f "/usr/lib/jvm/jre/bin/java" ]; then
    JAVA_EXECUTABLE="/usr/lib/jvm/jre/bin/java"
    echo "Using Java from JRE path: $JAVA_EXECUTABLE" >&2
  else
    # Last resort: search for any java executable
    echo "Searching for Java executable..." >&2
    java_path=$(find /usr -name java -type f -executable 2>/dev/null | head -1)
    if [ -n "$java_path" ]; then
      JAVA_EXECUTABLE="$java_path"
      echo "Found Java at: $java_path" >&2
    else
      echo "Error: Java executable not found" >&2
      exit 1
    fi
  fi
fi

# Verify Java executable exists and is executable
if [ ! -f "$JAVA_EXECUTABLE" ] || [ ! -x "$JAVA_EXECUTABLE" ]; then
  echo "Error: Java executable not found or not executable at $JAVA_EXECUTABLE" >&2
  exit 1
fi

# Print Java version for debugging
echo "Using Java executable: $JAVA_EXECUTABLE" >&2
$JAVA_EXECUTABLE -version >&2 2>&1

# JVM heap sizing (issue #24). In local[*] the driver and executor share this
# one JVM, so the old hard-coded -Xmx1g boxed the whole engine into 1 GB even
# on a multi-GB Lambda/container — a shuffle-heavy transform then exhausted the
# heap and GC-thrashed until the heartbeat thread stalled and the executor
# self-exited (looked like "plenty of free memory" because that was *container*
# memory, not the capped JVM heap). Size the heap to ~75% of the container,
# leaving room for JVM metaspace + off-heap shuffle buffers and the
# Python/pyspark side. Precedence:
#   CLAVESA_JVM_HEAP_MB (explicit override)
#   > 75% of AWS_LAMBDA_FUNCTION_MEMORY_SIZE (Lambda exposes its size in MB)
#   > 75% of the cgroup memory limit (a memory-capped local container)
#   > 1024 (unconstrained local fallback — unchanged from the old default).
heap_mb="${CLAVESA_JVM_HEAP_MB:-}"
if [ -z "$heap_mb" ] && [ -n "$AWS_LAMBDA_FUNCTION_MEMORY_SIZE" ]; then
  heap_mb=$(( AWS_LAMBDA_FUNCTION_MEMORY_SIZE * 3 / 4 ))
fi
if [ -z "$heap_mb" ]; then
  # cgroup v2 (memory.max) then v1 (memory.limit_in_bytes); skip "max" /
  # unlimited sentinels and the host total that leaks through when uncapped.
  for f in /sys/fs/cgroup/memory.max /sys/fs/cgroup/memory/memory.limit_in_bytes; do
    [ -r "$f" ] || continue
    lim=$(cat "$f")
    case "$lim" in
      ''|max|*[!0-9]*) continue ;;
    esac
    if [ "$lim" -gt 268435456 ] && [ "$lim" -lt 1099511627776 ]; then
      heap_mb=$(( lim / 1024 / 1024 * 3 / 4 ))
      break
    fi
  done
fi
heap_mb="${heap_mb:-1024}"
# Floor so a tiny limit can't produce an unusable heap.
[ "$heap_mb" -lt 512 ] && heap_mb=512
echo "[clavesa] spark-class JVM heap = ${heap_mb}m (lambda_mem=${AWS_LAMBDA_FUNCTION_MEMORY_SIZE:-none}MB, override=${CLAVESA_JVM_HEAP_MB:-none})" >&2

# Use Python 3.12 paths for PySpark. The --add-opens set mirrors Spark 4's
# JavaModuleOptions.java at the v4.0.2 tag — Java 17 module-system access
# the JVM denies by default but Spark's off-heap / unsafe paths need.
exec "$JAVA_EXECUTABLE" \
  --add-opens=java.base/java.lang=ALL-UNNAMED \
  --add-opens=java.base/java.lang.invoke=ALL-UNNAMED \
  --add-opens=java.base/java.lang.reflect=ALL-UNNAMED \
  --add-opens=java.base/java.io=ALL-UNNAMED \
  --add-opens=java.base/java.net=ALL-UNNAMED \
  --add-opens=java.base/java.nio=ALL-UNNAMED \
  --add-opens=java.base/java.util=ALL-UNNAMED \
  --add-opens=java.base/java.util.concurrent=ALL-UNNAMED \
  --add-opens=java.base/java.util.concurrent.atomic=ALL-UNNAMED \
  --add-opens=java.base/jdk.internal.ref=ALL-UNNAMED \
  --add-opens=java.base/sun.nio.ch=ALL-UNNAMED \
  --add-opens=java.base/sun.nio.cs=ALL-UNNAMED \
  --add-opens=java.base/sun.security.action=ALL-UNNAMED \
  --add-opens=java.base/sun.util.calendar=ALL-UNNAMED \
  --add-opens=java.security.jgss/sun.security.krb5=ALL-UNNAMED \
  -cp /var/lang/lib/python3.12/site-packages/pyspark/conf/:/var/lang/lib/python3.12/site-packages/pyspark/jars/* -Xmx${heap_mb}m "$@"
