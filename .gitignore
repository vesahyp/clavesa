.vscode
.claude/worktrees/
.claude/settings.local.json
.playwright-mcp
.playwright-cli
node_modules
# Root-anchored: with no leading slash, git matched ALL paths ending in
# `ui/dist/` — including `internal/ui/dist/`, which carries `.gitkeep` so
# `//go:embed all:dist` resolves without a UI build. Twin of the same trap
# on `dist/` below.
/ui/dist/
ui/.vite/
e2e/test-results
**/.terraform/
**/.terraform.lock.hcl
*.tfstate
*.tfstate.*
modules/**/*.zip
bin/
# Root-anchored: the top-level GoReleaser output. Without the leading slash,
# this ignored `internal/ui/dist/.gitkeep` too, defeating the placeholder
# whose whole job is to keep `//go:embed all:dist` happy on a fresh checkout.
/dist/
e2e/.e2e-workspace
/clavesa
__pycache__/
# Cloud smoke gate stamp (written by scripts/cloud-smoke.sh, read by release-check)
.cloud-smoke-green.json
